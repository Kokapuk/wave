{
  "name": "wave",
  "description": "Wave",
  "author": "Kokapuk",
  "version": "1.2.0",
  "private": true,
  "main": "./main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kokapuk/wave.git"
  },
  "scripts": {
    "vite:dev": "vite",
    "vite:build": "vite build",
    "electron:dev": "electron .",
    "electron:build": "electron-builder",
    "dev": "concurrently \"npm run vite:dev\" \"npm run electron:dev\"",
    "build": "npm run vite:build && npm run electron:build"
  },
  "build": {
    "appId": "com.electron.wave",
    "productName": "Wave",
    "directories": {
      "output": "dist/electron"
    },
    "win": {
      "target": "NSIS",
      "icon": "public/favicon.ico"
    },
    "files": [
      "!.vscode",
      "!dist/electron",
      "!public",
      "!src",
      "!.env",
      "!.gitignore",
      "!env.d.ts",
      "!index.html",
      "!README.md",
      "!tsconfig.config.json",
      "!tsconfig.json",
      "!vite.config.json"
    ]
  },
  "publish": {
    "provider": "github",
    "releaseType": "release"
  },
  "dependencies": {
    "@electron/remote": "^2.0.9",
    "axios": "^1.2.1",
    "electron-is-dev": "^2.0.0",
    "electron-updater": "^5.3.0",
    "nodejs-file-downloader": "^4.10.3"
  },
  "devDependencies": {
    "@types/node": "^18.11.12",
    "@vitejs/plugin-vue": "^4.0.0",
    "@vue/tsconfig": "^0.1.3",
    "electron": "^22.0.0",
    "electron-builder": "^23.6.0",
    "npm-run-all": "^4.1.5",
    "pinia": "^2.0.28",
    "typescript": "~4.7.4",
    "uid": "^2.0.1",
    "vite": "^4.0.0",
    "vue": "^3.2.45",
    "vue-router": "^4.1.6",
    "vue-tsc": "^1.0.12"
  }
}
