{
  "name": "wave",
  "description": "Wave",
  "author": "Kokapuk",
  "version": "1.0.0",
  "private": true,
  "main": "./main.js",
  "repository": "https://github.com/Kokapuk/wave.git",
  "scripts": {
    "vite:dev": "vite",
    "vite:build": "vite build",
    "electron:dev": "electron .",
    "electron:build": "electron-packager . \"Wave\" --overwrite --asar --platform=win32 --arch=ia32 --ignore=vite.config.js --ignore=README.md --ignore=.gitignore --ignore=\"^/index.html\" --ignore=\"^/src\" --ignore=.vscode --ignore=\"^/public\" --ignore=\"^/dist/electron\" --ignore=\"^/installer-creator.js\" --icon=public/favicon.ico --prune=true --out=dist/electron",
    "dev": "concurrently \"npm run vite:dev\" \"npm run electron:dev\"",
    "build": "npm run vite:build && npm run electron:build && node .\\installer-creator.js"
  },
  "dependencies": {
    "@electron/remote": "^2.0.9",
    "axios": "^1.2.1",
    "electron-is-dev": "^2.0.0",
    "electron-squirrel-startup": "^1.0.0",
    "nodejs-file-downloader": "^4.10.3"
  },
  "devDependencies": {
    "@types/node": "^18.11.12",
    "@vitejs/plugin-vue": "^4.0.0",
    "@vue/tsconfig": "^0.1.3",
    "electron": "^22.0.0",
    "electron-packager": "^17.1.1",
    "electron-winstaller": "^5.1.0",
    "npm-run-all": "^4.1.5",
    "pinia": "^2.0.28",
    "typescript": "~4.7.4",
    "uid": "^2.0.1",
    "vite": "^4.0.0",
    "vue": "^3.2.45",
    "vue-router": "^4.1.6",
    "vue-tsc": "^1.0.12"
  }
}
